<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.uniquindio.poo.taller.viewcontroller.MecanicoViewController">

    <!-- Barra de navegación superior -->
    <top>
        <HBox style="-fx-background-color: #34495e; -fx-padding: 15;" spacing="15" alignment="CENTER_LEFT">
            <Button text="🏠 MENÚ PRINCIPAL" onAction="#onVolver" styleClass="boton-volver" />
            <Label text="GESTIÓN DE MECÁNICOS" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;" HBox.hgrow="ALWAYS" />
            <Label text="𝐓𝐀𝐋𝐋𝐄𝐑 𝐔𝐐" style="-fx-text-fill: #f1c40f; -fx-font-weight: bold;" />
        </HBox>
    </top>

    <!-- Contenido central -->
    <center>
        <VBox style="-fx-background-color: #f5f5f5; -fx-padding: 20;" spacing="20">

            <!-- Panel de formulario -->
            <VBox styleClass="panel-formulario" spacing="15">
                <Label text="🔧 REGISTRO DE MECÁNICOS" styleClass="titulo-seccion" />

                <GridPane hgap="15" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints minWidth="120" />
                        <ColumnConstraints minWidth="300" />
                    </columnConstraints>

                    <Label text="ID Mecánico:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;" />
                    <TextField fx:id="txtId" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="campo-texto" promptText="Ej: M001, M002" />

                    <Label text="Nombre completo:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;" />
                    <TextField fx:id="txtNombre" GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="campo-texto" promptText="Nombre del mecánico" />

                    <Label text="Especialidad:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;" />
                    <TextField fx:id="txtEspecialidad" GridPane.rowIndex="2" GridPane.columnIndex="1" styleClass="campo-texto" promptText="Ej: Frenos, Suspensión, Eléctricas" />

                    <Label text="Núm. Certificación:" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold;" />
                    <TextField fx:id="txtCertificacion" GridPane.rowIndex="3" GridPane.columnIndex="1" styleClass="campo-texto" promptText="Ej: CERT001, CERT002" />
                </GridPane>

                <!-- Botones de acción -->
                <HBox spacing="15" alignment="CENTER">
                    <Button text="➕ AGREGAR MECÁNICO" onAction="#onAgregar" styleClass="boton-exito" prefWidth="200" />
                    <Button text="🔄 ACTUALIZAR" onAction="#onActualizar" styleClass="boton-primario" prefWidth="120" />
                    <Button text="🗑️ ELIMINAR" onAction="#onEliminar" styleClass="boton-peligro" prefWidth="120" />
                    <Button text="🧹 LIMPIAR" onAction="#onLimpiar" styleClass="boton-secundario" prefWidth="120" />
                </HBox>
            </VBox>

            <!-- Panel de tabla -->
            <VBox styleClass="panel-tabla" spacing="15">
                <Label text="📋 LISTA DE MECÁNICOS" styleClass="titulo-seccion" />

                <TableView fx:id="tblMecanicos" VBox.vgrow="ALWAYS" prefHeight="250">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="100" text="ID" />
                        <TableColumn fx:id="colNombre" prefWidth="200" text="NOMBRE" />
                        <TableColumn fx:id="colEspecialidad" prefWidth="180" text="ESPECIALIDAD" />
                        <TableColumn fx:id="colCertificacion" prefWidth="180" text="CERTIFICACIÓN" />
                    </columns>
                </TableView>

                <Label fx:id="lblTotalMecanicos" text="Total mecánicos: 0" styleClass="label-info" />
            </VBox>
        </VBox>
    </center>

    <stylesheets>
        <String fx:value="/styles/application.css" />
    </stylesheets>
</BorderPane>