<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.uniquindio.poo.taller.viewcontroller.HistorialViewController">

    <!-- Barra de navegación superior -->
    <top>
        <HBox style="-fx-background-color: #34495e; -fx-padding: 15;" spacing="15" alignment="CENTER_LEFT">
            <Button text="🏠 MENÚ PRINCIPAL" onAction="#onVolver" styleClass="boton-volver" />
            <Label text="📊 HISTORIAL DE SERVICIOS POR BICICLETA" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;" HBox.hgrow="ALWAYS" />
            <Label text="𝐓𝐀𝐋𝐋𝐄𝐑 𝐔𝐐" style="-fx-text-fill: #f1c40f; -fx-font-weight: bold;" />
        </HBox>
    </top>

    <!-- Contenido central -->
    <center>
        <VBox style="-fx-background-color: #f5f5f5; -fx-padding: 20;" spacing="20">

            <!-- Panel de búsqueda -->
            <VBox styleClass="panel-formulario" spacing="15">
                <Label text="🔍 BUSCAR BICICLETA" styleClass="titulo-seccion" />

                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="Seleccione o escriba serial:" style="-fx-font-weight: bold;" />
                    <ComboBox fx:id="cbBicicletas" prefWidth="400" editable="true" promptText="Seleccione una bicicleta o escriba el serial" />
                    <Button text="🔍 BUSCAR" onAction="#onBuscar" styleClass="boton-primario" />
                    <Button text="🧹 LIMPIAR" onAction="#onLimpiar" styleClass="boton-secundario" />
                </HBox>
            </VBox>

            <!-- Panel de información de la bicicleta -->
            <VBox styleClass="panel-formulario" spacing="10">
                <Label text="🚲 INFORMACIÓN DE LA BICICLETA" styleClass="titulo-seccion" />

                <GridPane hgap="20" vgap="5">
                    <columnConstraints>
                        <ColumnConstraints minWidth="100" />
                        <ColumnConstraints minWidth="200" />
                        <ColumnConstraints minWidth="100" />
                        <ColumnConstraints minWidth="200" />
                    </columnConstraints>

                    <Label text="Serial:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;" />
                    <Label fx:id="lblSerial" text="-" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                    <Label text="Marca:" GridPane.rowIndex="0" GridPane.columnIndex="2" style="-fx-font-weight: bold;" />
                    <Label fx:id="lblMarca" text="-" GridPane.rowIndex="0" GridPane.columnIndex="3" />

                    <Label text="Tipo:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;" />
                    <Label fx:id="lblTipo" text="-" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                    <Label text="Propietario:" GridPane.rowIndex="1" GridPane.columnIndex="2" style="-fx-font-weight: bold;" />
                    <Label fx:id="lblCliente" text="-" GridPane.rowIndex="1" GridPane.columnIndex="3" />
                </GridPane>
            </VBox>

            <!-- Panel de historial -->
            <VBox styleClass="panel-tabla" spacing="15" VBox.vgrow="ALWAYS">
                <Label text="📋 HISTORIAL DE SERVICIOS" styleClass="titulo-seccion" />

                <TableView fx:id="tblHistorial" VBox.vgrow="ALWAYS" prefHeight="300">
                    <columns>
                        <TableColumn fx:id="colFecha" prefWidth="90" text="FECHA" />
                        <TableColumn fx:id="colHora" prefWidth="70" text="HORA" />
                        <TableColumn fx:id="colMecanico" prefWidth="150" text="MECÁNICO" />
                        <TableColumn fx:id="colDiagnostico" prefWidth="150" text="DIAGNÓSTICO" />
                        <TableColumn fx:id="colTrabajos" prefWidth="200" text="TRABAJOS REALIZADOS" />
                        <TableColumn fx:id="colCosto" prefWidth="90" text="COSTO" />
                        <TableColumn fx:id="colEstado" prefWidth="90" text="ESTADO" />
                    </columns>
                </TableView>

                <Label fx:id="lblTotalServicios" text="Total servicios: 0" styleClass="label-info" />
            </VBox>
        </VBox>
    </center>

    <stylesheets>
        <String fx:value="/styles/application.css" />
    </stylesheets>
</BorderPane>